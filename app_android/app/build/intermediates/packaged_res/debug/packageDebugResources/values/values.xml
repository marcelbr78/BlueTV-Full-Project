<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="accent_orange">#f59e0b</color>
    <color name="accent_red">#e50914</color>
    <color name="bg_dark">#1a0a0a</color>
    <color name="bg_darker">#0d0505</color>
    <color name="card_bg">#2a1010</color>
    <color name="overlay">#88000000</color>
    <color name="tab_normal">#ffffff</color>
    <color name="tab_selected">#e50914</color>
    <color name="text_gray">#aaaaaa</color>
    <color name="text_white">#ffffff</color>
    <style name="Theme.BlueTV" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_darker</item>
        <item name="android:navigationBarColor">@color/bg_darker</item>
        <item name="android:windowFullscreen">true</item>
    </style>
    <style name="Theme.BlueTV.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar"/>
    <style name="Theme.BlueTV.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
    <style name="Theme.BlueTV.PopupOverlay" parent="ThemeOverlay.AppCompat.Light"/>
</resources>